# Copy to .env and fill in your keys.
ANTHROPIC_API_KEY=
FIRECRAWL_API_KEY=
DISCORD_BOT_TOKEN=

# Optional: your Discord server (guild) ID. If set, slash commands are synced to
# that server instantly on startup (great for development). If unset, commands
# sync globally and new/changed ones can take up to ~1 hour to appear.
# Get it via Discord: Settings > Advanced > Developer Mode, then right-click your
# server icon > Copy Server ID.
DISCORD_GUILD_ID=

# Optional: your name/suffix used in generated filenames, e.g.
# <company>_resume_<RESUME_OWNER>.pdf. Sanitized to be filename-safe.
# Defaults to "candidate" if unset.
RESUME_OWNER=

# Optional but recommended: a short profile of the candidate, injected into the
# prompts to steer job scoring / cover letters / resume tailoring. Kept out of
# source so your background isn't in a public repo. Multi-line values must be
# wrapped in double quotes (as below). If unset, the app relies on the attached
# resume alone.
CANDIDATE_PROFILE="- Experience level: (e.g. Junior, ~1 year of project work)
- Core stack: (e.g. Python, Flask, React, PostgreSQL)
- Strengths: (key tools/frameworks)
- No experience with: (things to avoid claiming)
- Degree: (e.g. Associate's in Computer Science)"

# Optional: logging verbosity (DEBUG, INFO, WARNING, ...)
LOG_LEVEL=INFO

# Optional: max concurrent per-job scrape/evaluation calls (default: 5).
# Higher = faster, but more likely to hit Firecrawl/Anthropic rate limits.
JOB_SCRAPER_WORKERS=5
